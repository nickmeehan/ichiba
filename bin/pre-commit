#!/bin/bash

# pre-commit hook — validates plugin and marketplace schemas
# Install: ln -sf ../../bin/pre-commit .git/hooks/pre-commit

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Only run if manifest files are staged
STAGED=$(git diff --cached --name-only)
if echo "$STAGED" | grep -qE '(plugin\.json|marketplace\.json)'; then
    echo "Validating plugin schemas..."
    "$SCRIPT_DIR/validate-plugin.sh"
fi
